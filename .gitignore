```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build outputs
dist/
build/
target/

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# Python specific
.mypy_cache/
.pytest_cache/

# OS generated
.DS_Store
Thumbs.db
```